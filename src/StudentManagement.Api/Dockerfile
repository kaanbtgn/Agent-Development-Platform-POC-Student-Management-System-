# Build stage — tüm src/ kopyalanır çünkü projelere ProjectReference var
FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src

COPY src/ src/

RUN dotnet restore src/StudentManagement.Api/StudentManagement.Api.csproj

RUN dotnet publish src/StudentManagement.Api/StudentManagement.Api.csproj \
    -c Release -o /app/publish --no-restore

# Runtime stage
FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS final
WORKDIR /app

COPY --from=build /app/publish .

ENV ASPNETCORE_HTTP_PORTS=8080
EXPOSE 8080

ENTRYPOINT ["dotnet", "StudentManagement.Api.dll"]
