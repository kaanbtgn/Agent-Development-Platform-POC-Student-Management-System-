# Bu dosyayı .env.docker olarak kopyalayın ve değerleri doldurun.
# docker compose komutunu şu şekilde çalıştırın:
# docker compose --env-file .env.docker up --build

# CORS
ALLOWED_ORIGIN=http://localhost

# PostgreSQL
POSTGRES_DB=studentmanagement
POSTGRES_USER=studentmanagement
POSTGRES_PASSWORD=studentmanagement

# MongoDB
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=password

# Redis
REDIS_CONNECTION=redis:6379

# Azure OpenAI  (Agent için zorunlu — boşsa AI özellikleri devre dışı kalır)
AzureOpenAI__Endpoint=https://<your-resource>.openai.azure.com/
AzureOpenAI__ApiKey=
AzureOpenAI__DeploymentName=gpt-4o

# Azure Document Intelligence  (Agent için, OCR özelliği)
AzureDocumentIntelligence__Endpoint=https://<your-resource>.cognitiveservices.azure.com/
AzureDocumentIntelligence__ApiKey=
